# ──────────────────────────────────────────────────────────
# DOMAIN CONFIGURATION — edit only this file, never others
# ──────────────────────────────────────────────────────────

# Base domain for Matrix user IDs  →  @user:example.com
# Set equal to SYNAPSE_DOMAIN for simpler @user:matrix.example.com IDs
MATRIX_DOMAIN=example.com

# Where the Synapse server is publicly reachable
SYNAPSE_DOMAIN=matrix.example.com

# Where Keycloak (SSO) is publicly reachable
KEYCLOAK_DOMAIN=auth.example.com

# Where the TURN server is publicly reachable
TURN_DOMAIN=turn.example.com

# Public IP of this server (required for TURN NAT traversal)
SERVER_IP=1.2.3.4

# ──────────────────────────────────────────────────────────
# LET'S ENCRYPT
# ──────────────────────────────────────────────────────────
CERTBOT_EMAIL=admin@example.com

# ──────────────────────────────────────────────────────────
# POSTGRESQL
# Avoid special characters ($  '  \  &  |) in passwords.
# ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_postgres
SYNAPSE_DB_PASSWORD=change_me_synapse
KEYCLOAK_DB_PASSWORD=change_me_keycloak
MAS_DB_PASSWORD=change_me_mas

# ──────────────────────────────────────────────────────────
# SYNAPSE
# ──────────────────────────────────────────────────────────
SYNAPSE_REGISTRATION_SECRET=change_me_registration_secret

# ──────────────────────────────────────────────────────────
# COTURN  (value must match Synapse's turn_shared_secret)
# ──────────────────────────────────────────────────────────
TURN_SECRET=change_me_turn_secret

# ──────────────────────────────────────────────────────────
# KEYCLOAK
# ──────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin

# ──────────────────────────────────────────────────────────
# MAS (Matrix Authentication Service)
# Avoid special characters ($  '  \  &  |) in passwords.
# ──────────────────────────────────────────────────────────
MAS_ENCRYPTION_SECRET=change_me_64_hex_chars
MAS_MATRIX_SECRET=change_me_mas_matrix_secret
MAS_SYNAPSE_CLIENT_SECRET=change_me_mas_synapse_client_secret

# Pre-generated secret — paste this value into Keycloak when creating the mas client
MAS_KEYCLOAK_CLIENT_SECRET=change_me_mas_keycloak_client_secret
